{
	"info": {
		"name": "Smart Library Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Admin",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "http://localhost:5000/api/auth/register", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "register"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@library.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"url": {"raw": "http://localhost:5000/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "login"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@library.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Books",
			"item": [
				{
					"name": "Get All Books",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:5000/api/books", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "books"]}
					}
				},
				{
					"name": "Add Book (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
						],
						"url": {"raw": "http://localhost:5000/api/books", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "books"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"The Great Gatsby\",\n  \"author\": \"F. Scott Fitzgerald\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Issues & Returns",
			"item": [
				{
					"name": "Issue Book",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
						],
						"url": {"raw": "http://localhost:5000/api/issue/issue", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "issue", "issue"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bookId\": \"BOOK_ID_HERE\"\n}"
						}
					}
				},
				{
					"name": "Return Book",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE"}
						],
						"url": {"raw": "http://localhost:5000/api/issue/return", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "issue", "return"]},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bookId\": \"BOOK_ID_HERE\"\n}"
						}
					}
				}
			]
		}
	]
}
