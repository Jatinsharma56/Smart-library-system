+function initTheme() {
+  const storedTheme = localStorage.getItem('libraryHubTheme') || 'dark';
+  if (storedTheme === 'dark') {
+    document.body.classList.add('dark-mode');
+    if (darkModeToggleEl) darkModeToggleEl.checked = true;
+  } else {
+    document.body.classList.remove('dark-mode');
+    if (darkModeToggleEl) darkModeToggleEl.checked = false;
+  }
+}
+
+if (darkModeToggleEl) {
+  darkModeToggleEl.addEventListener('change', (e) => {
+    if (e.target.checked) {
+      document.body.classList.add('dark-mode');
+      localStorage.setItem('libraryHubTheme', 'dark');
+    } else {
+      document.body.classList.remove('dark-mode');
+      localStorage.setItem('libraryHubTheme', 'light');
+    }
+  });
+}
